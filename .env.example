# Copy to .env and fill in. .env is gitignored.

# === REQUIRED — generate strong random values (`openssl rand -hex 32`) ===
OWNER_TOKEN=replace-with-strong-random-token-min-32-chars
HMAC_SECRET=replace-with-separate-random-hmac-secret-min-32-chars

# === LLM (subscription-only via `claude -p`; NO ANTHROPIC_API_KEY here) ===
LLM_MODEL_HAIKU=claude-haiku-4-5
LLM_MODEL_SONNET=claude-sonnet-4-6
LLM_MODEL_OPUS=claude-opus-4-7

# Subscription quota tracking — approximate tokens-equivalent
LLM_MONTHLY_QUOTA_TOKENS=10000000
LLM_QUOTA_SOFT_WARN_PCT=70
LLM_QUOTA_PAUSE_PCT=90

# === Postgres ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ai_team
POSTGRES_PASSWORD=changeme-local-only
POSTGRES_DB=ai_team
POSTGRES_DSN=postgresql+asyncpg://ai_team:changeme-local-only@localhost:5432/ai_team

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# === API ===
API_HOST=0.0.0.0
API_PORT=8000

# === Observability ===
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# === Target repo (default: self-bootstrap) ===
DEFAULT_TARGET_REPO=.
DEFAULT_TARGET_REPO_BRANCH=develop

# === Checkpoint cadence (minutes) ===
CHECKPOINT_INTERVAL_MIN=30
