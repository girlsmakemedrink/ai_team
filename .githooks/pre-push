#!/usr/bin/env bash
# Pre-push hook — fail fast on formatting / lint / unit-test issues.
#
# Installed by `make install-hooks` (which targets the per-worktree
# hooks dir found by `git rev-parse --git-path hooks`, so it's safe to
# run from both the main checkout and from any worktree).
#
# We deliberately use `ruff format --check` rather than `ruff format`
# so the hook never modifies your working tree right before push.
# If this hook fails: run `make fix` to auto-apply, then re-push.
#
# Integration / real-LLM tests are NOT run here — too slow and they
# need infra. Run `make test-integration` or `make test-real-llm`
# separately when relevant.
#
# Skip the hook (rare, e.g. emergency): `git push --no-verify`.
# CLAUDE.md asks Claude not to use --no-verify; humans can.

set -euo pipefail

echo "[pre-push] make lint"
make lint

echo "[pre-push] ruff format --check"
uv run ruff format --check .

echo "[pre-push] make test-unit"
# Integration tests need infra (testcontainers / docker) and are too
# heavy for a per-push hook — CI runs them. Unit tests are fast and
# infra-free; that's enough local pre-push protection.
make test-unit

echo "[pre-push] OK — pushing"
