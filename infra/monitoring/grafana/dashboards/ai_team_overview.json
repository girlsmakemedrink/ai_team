{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "title": "AI Team — Overview",
  "tags": ["ai_team"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Subscription quota used (%)",
      "targets": [{ "expr": "subscription_quota_used_pct", "refId": "A" }],
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Pending human approvals",
      "targets": [{ "expr": "agent_human_approvals_pending", "refId": "A" }],
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Bus queue depth",
      "targets": [{ "expr": "sum(message_bus_queue_depth)", "refId": "A" }],
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "LLM tokens by agent",
      "targets": [{
        "expr": "sum by (agent) (rate(agent_llm_tokens_used_total[5m]))",
        "refId": "A"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "title": "Errors by agent",
      "targets": [{
        "expr": "sum by (agent) (rate(agent_errors_total[5m]))",
        "refId": "A"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    }
  ]
}
